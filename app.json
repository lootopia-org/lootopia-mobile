{
  "expo": {
    "name": "Lootopia Mobile",
    "slug": "lootopia-mobile",
    "scheme": "lootopia",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fff4ec"
      }
    }
  }
}
